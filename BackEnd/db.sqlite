CREATE TABLE photos (
    idPhotos INTEGER PRIMARY KEY,
    datePhotos INTEGER,
    CheminAcces TEXT NOT NULL,
    IdUtilisateurs INTEGER,
    IdPlantes INTEGER,
    FOREIGN KEY (idUtilisateurs) REFERENCES utilisateurs(idUtilisateurs),
    FOREIGN KEY (idPlantes) REFERENCES Plantes(idPlantes)
);

CREATE TABLE utilisateurs (
    idUtilisateurs INTEGER PRIMARY KEY,
    nom VARCHAR(100),
    prenom VARCHAR(100),
    email VARCHAR(255),
    Password VARCHAR(100),
    photo VARCHAR(255),
    Botaniste BOOLEAN,  -- boolÃ©en pour un  (0 ou 1) 
    numero VARCHAR(15),
    Adresse VARCHAR(255)
);


